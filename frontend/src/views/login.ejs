<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Đăng nhập hệ thống</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header>
    <h1>Hệ thống quản lý dự án phần mềm sinh viên</h1>
    <p>Đăng nhập và chuyển tới trang theo chức vụ</p>
  </header>

  <main class="login-wrap">
    <section class="card login-card">
      <h2>Đăng nhập</h2>
      <label for="backendUrl">Backend URL</label>
      <input id="backendUrl" value="<%= backendUrl %>" />

      <form id="loginForm">
        <input name="username" placeholder="Tên đăng nhập" required />
        <input name="password" type="password" placeholder="Mật khẩu" required />
        <button type="submit">Đăng nhập</button>
      </form>

      <pre id="output">Sẵn sàng.</pre>
    </section>
  </main>

  <script src="/login.js"></script>
</body>
</html>
